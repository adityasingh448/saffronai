# Required for OpenAI-generated scripts. If omitted, the app uses a local deterministic script writer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Primary voice provider. The app fetches saved/custom ElevenLabs voices for selection.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_v3

# Optional brand defaults.
BRAND_NAME=Saffron AI
DEFAULT_LANGUAGE=English

# Video renderer. Remotion gives the highest-quality zoom/highlight output.
VIDEO_RENDERER=remotion
REMOTION_TEMPLATE_DIR=remotion-report
REMOTION_FPS=60
REMOTION_CRF=18
REMOTION_CODEC=h264
REMOTION_TIMEOUT_SECONDS=7200
REMOTION_CONCURRENCY=

# Legacy HyperFrames renderer settings, kept only if VIDEO_RENDERER=hyperframes.
HYPERFRAMES_PACKAGE=hyperframes@0.7.22
HYPERFRAMES_QUALITY=medium
HYPERFRAMES_FPS=30
HYPERFRAMES_RENDER_TIMEOUT_SECONDS=7200
HYPERFRAMES_MEDIA_TOOLS_DIR=data/tools/hyperframes-media
HYPERFRAMES_FFPROBE_PACKAGE=ffprobe-static@3.1.0

# Optional: real lip-sync presenter. Select "HeyGen lip-sync" in the UI after setting these.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
