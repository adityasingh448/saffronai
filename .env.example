# Required for OpenAI-generated scripts. If omitted, the app uses a local deterministic script writer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Preferred voice provider for generated report videos.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=aura-2-orpheus-en
DEEPGRAM_SPEED=1.0
DEEPGRAM_MIP_OPT_OUT=true

# Optional fallback voice provider. If omitted, the app uses Windows local speech as demo fallback.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional brand defaults.
BRAND_NAME=Saffron AI
DEFAULT_LANGUAGE=English

# Video renderer. The local renderer is optimized for fast turnaround.
VIDEO_RENDERER=local
HYPERFRAMES_PACKAGE=hyperframes@0.7.22
HYPERFRAMES_QUALITY=medium
HYPERFRAMES_FPS=30
HYPERFRAMES_RENDER_TIMEOUT_SECONDS=7200
HYPERFRAMES_MEDIA_TOOLS_DIR=data/tools/hyperframes-media
HYPERFRAMES_FFPROBE_PACKAGE=ffprobe-static@3.1.0

# Optional: real lip-sync presenter. Select "HeyGen lip-sync" in the UI after setting these.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
